__pycache__/
*.py[cod]
*$py.class
*.so
*.pyo
.Python
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
.eggs/
dist/
*.egg

# ── Precomputed / large binary data ───────────────────────
# PDB structure files can be tens of MB — fetch at runtime
public/precomputed/*.pdb
public/precomputed/*.pdbqt
*.pdb
*.pdbqt
*.mol2
*.sdf

# ── Database files ────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Logs ─────────────────────────────────────────────────
*.log
logs/
*.out

